						"    pm.response.to.have.status(200);",
						"    var json = pm.response.json();",
						"    pm.expect(json.memberIds.length).to.be.at.least(2);",
						"    // Capturar memberId do response (o que NAO e o adminId)",
						"    var adminId = pm.collectionVariables.get('adminId');",
						"    var ids = json.memberIds.filter(function(id) { return id != adminId; });",
						"    if (ids.length > 0) pm.collectionVariables.set('memberId', ids[0]);",
						"});"
					], "type": "text/javascript" }}],
					"request": {
